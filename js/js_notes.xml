<root>
	<windowclass name="js_notes">
		<sheetdata>
			<anchor_content_top />
			<anchor_content_bottom />

			<sub_content_framed_groupbox name="content">
				<class>js_notes_content</class>
			</sub_content_framed_groupbox>
			<scrollbar_content />
		</sheetdata>
	</windowclass>

	<windowclass name="js_notes_content">
		<sheetdata>
			<anchor_content_top>
				<anchored>
					<left offset="10" />
					<right offset="-10" />
				</anchored>
			</anchor_content_top>

			<sub_content_top name="sub_header">
				<class>js_main_header</class>
			</sub_content_top>

			<sub_content_top name="sub_crew">
				<anchored width="270">
					<right merge="delete" />
					<top relation="current" />
				</anchored>
				<class>js_main_crew</class>
				<noscroll />
			</sub_content_top>

			<sub_content_top name="sub_details">
				<anchored>
					<left parent="sub_crew" anchor="right" offset="20" />
				</anchored>
				<class>sub_notes_details</class>
				<noscroll />
			</sub_content_top>
		</sheetdata>
	</windowclass>

	<windowclass name="sub_notes_details">
		<margins control="0,0,0,5" />
		<sheetdata>
			<anchor_content_top />

			<header_content_framed_headersimple name="header_playernotes">
				<static textres="js_header_notes" />
			</header_content_framed_headersimple>

			<js_button_playeredit name="notes_edit">
				<anchored to="header_playernotes" position="insidetopright" offset="-2,0" />
				<path>job.notes</path>
				<titleres>js_edit_header_jobnotes</titleres>
			</js_button_playeredit>

			<ft_content_top name="notes" source="job.notes" />
		</sheetdata>
	</windowclass>
</root>
