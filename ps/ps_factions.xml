<root>
	<windowclass name="ps_factions">
		<sheetdata>
			<anchor_content_top />
			<anchor_content_bottom />

			<sub_content_framed_groupbox name="content">
				<class>ps_factions_content</class>
			</sub_content_framed_groupbox>
			<scrollbar_content />
		</sheetdata>
	</windowclass>

	<windowclass name="ps_factions_content">
		<margins control="0,0,0,5" />
		<sheetdata>
			<anchor_content_top>
				<anchored>
					<left offset="10" />
					<right offset="-10" />
				</anchored>
			</anchor_content_top>
			<anchor_content_bottom />

			<spacer_content_top>
				<anchored height="10" />
			</spacer_content_top>

			<list_content_noscroll_top name="list">
				<datasource>.factions</datasource>
				<allowdelete />
				<class>ps_faction</class>
				<script>
					function onSortCompare(w1, w2)
						local t1 = w1.getFactionTier();
						local t2 = w2.getFactionTier();

						if t1 ~= t2 then
							return t1 &gt; t2;
						end

						local n1 = w1.getFactionName();
						local n2 = w2.getFactionName();
						
						if StringManager.startsWith(n1, "The ") then
							n1 = string.sub(n1, 5, -1);
						end
						if StringManager.startsWith(n2, "The ") then
							n2 = string.sub(n2, 5, -1);
						end

						return n1 &gt; n2;
					end
				</script>
			</list_content_noscroll_top>
		</sheetdata>
	</windowclass>

	<windowclass name="ps_faction">
		<margins control="0,0,0,10" />
		<script file="ps/scripts/ps_faction.lua" />
		<sheetdata>
			<anchor_content_top />
			<anchor_content_bottom />

			<hn name="status">
				<default>0</default>
			</hn>

			<label_crewframe_top_right name="header" />

			<bg_rating name="bg">
				<anchored to="header">
					<right offset="-26" />
				</anchored>
				<control>status</control>
				<source>status</source>
			</bg_rating>
			<buttongroup_factionstatus name="status">
				<anchored to="header" />
			</buttongroup_factionstatus>
			<linkfield_record name="link">
				<anchored to="header" height="20" width="20" position="insidetopright" offset="0,5" />
				<class>faction</class>
			</linkfield_record>

			<sub_content_top name="content">
				<class>ps_faction_content</class>
			</sub_content_top>
		</sheetdata>
	</windowclass>

	<windowclass name="ps_faction_content">
		<script file="ps/scripts/ps_faction_content.lua" />
		<sheetdata>
			<anchor_content_top />
			<anchor_content_bottom />

			<hn name="status">
				<default>0</default>
			</hn>

			<spacer_content_top />

			<sub_content_top name="goal">
				<anchored width="110">
					<top relation="current" />
					<left offset="5" />
					<right merge="delete" />
				</anchored>
				<class>ps_faction_goal</class>
			</sub_content_top>

			<ftc_content_column_full name="description">
				<anchored>
					<left parent="goal" anchor="right" offset="5" />
					<right parent="" offset="-40" />
				</anchored>
				<script>
					function onInit()
						local node = window.getFactionNode();
						DB.addHandler(DB.getPath(node, "description.value"), "onUpdate", update)
						self.update();
					end
					function onClose()
						local node = window.getFactionNode();
						DB.removeHandler(DB.getPath(node, "description.value"), "onUpdate", update)
					end
					function update()
						local node = window.getFactionNode();
						setValue(DB.getValue(node, "description.value", ""));
					end
				</script>
				<readonly />
			</ftc_content_column_full>

			<basicnumber name="jobcount">
				<anchored height="20" width="30">
					<top parent="description" />
					<right parent="" offset="-5" />
				</anchored>
				<min>0</min>
			</basicnumber>

			<header_content_framed_headersimple name="notes_header">
				<anchored>
					<left parent="goal" anchor="right" offset="5" />
				</anchored>
				<static textres="ps_title_playernotes" />
			</header_content_framed_headersimple>

			<ps_button_playeredit name="notes_edit">
				<anchored to="notes_header" position="insidetopright" />
				<path>notes</path>
				<titleres>ps_edit_header_factionnotes</titleres>
			</ps_button_playeredit>

			<ft_content_column_full name="notes">
				<anchored>
					<left parent="goal" anchor="right" offset="5" />
				</anchored>
			</ft_content_column_full>
		</sheetdata>
	</windowclass>

	<windowclass name="ps_faction_goal">
		<script>
			function updateClock(nSize, nProgress)
				goalclock.update(nSize, nProgress)
			end
		</script>
		<sheetdata>
			<anchor_content_top />
			<anchor_content_bottom />
			
			<button_clock_faction name="goalclock" />
			<string_content_noframe_static_top name="description">
				<anchored>
					<right offset="0" />
				</anchored>
				<center />
			</string_content_noframe_static_top>
		</sheetdata>
	</windowclass>
</root>