<root>
	<windowclass name="ps_heat">
		<sheetdata>
			<anchor_content_top />
			<anchor_content_bottom />

			<sub_content_framed_groupbox name="content">
				<class>ps_heat_main</class>
			</sub_content_framed_groupbox>
			<scrollbar_content />
		</sheetdata>
	</windowclass>

	<windowclass name="ps_heat_main">
		<margins control="0,0,0,5" />
		<sheetdata>
			<anchor_content_top>
				<anchored>
					<left offset="10" />
					<right offset="-10" />
				</anchored>
			</anchor_content_top>
			<anchor_content_bottom />

			<spacer_content_top>
				<anchored height="10" />
			</spacer_content_top>

			<list_content_noscroll_top name="list">
				<datasource>.systems</datasource>
				<allowdelete />
				<class>ps_system</class>
			</list_content_noscroll_top>
		</sheetdata>
	</windowclass>

	<windowclass name="ps_system">
		<margins control="0,0,0,5" />
		<script file="ps/scripts/ps_system.lua" />
		<sheetdata>
			<anchor_content_top />
			<anchor_content_bottom />

			<spacer_content_top>
				<anchored height="8" />
			</spacer_content_top>

			<label_crewframe_top_right name="header_background" />

			<anchor_header_right>
				<anchored to="header_background" />
			</anchor_header_right>
			<anchor_header_left>
				<anchored to="header_background" />
			</anchor_header_left>

			<hn name="wantedclockprogress" source="wantedclock.progress">
				<default>0</default>
			</hn>
			<hn name="wantedclocksize" source="wantedclock.size">
				<default>6</default>
			</hn>
			<ps_wanted_clock name="wanted_clock" />

			<link_listitem_left name="link">
				<anchored to="leftanchor">
					<top offset="5" />
					<left offset="-5" />
				</anchored>
				<class>system</class>
			</link_listitem_left>

			<bg_rating name="wanted_bg">
				<anchored to="rightanchor">
					<right relation="current" offset="3" />
				</anchored>
				<control>wanted</control>
				<source>wanted</source>
			</bg_rating>
			<ps_buttongroup_rating_title_red name="wanted">
				<anchored to="rightanchor">
					<right relation="relative" offset="-1" />
				</anchored>
				<values>
					<maximum>4</maximum>
				</values>
				<sourcefields>
					<current>wanted</current>
				</sourcefields>
			</ps_buttongroup_rating_title_red>
			<label_crewheader name="wanted_header">
				<static textres="ps_title_wanted" />
				<anchored to="rightanchor" width="70">
					<right relation="relative" offset="-5" />
					<top offset="5" />
				</anchored>
			</label_crewheader>

			<bg_rating name="heat_bg">
				<anchored to="rightanchor">
					<right relation="current" offset="-7" />
				</anchored>
				<control>heat</control>
				<source>heat</source>
			</bg_rating>
			<ps_buttongroup_rating_title_red name="heat">
				<anchored to="rightanchor">
					<right relation="relative" offset="-11" />
				</anchored>
				<values>
					<maximum>8</maximum>
				</values>
				<sourcefields>
					<current>heat</current>
				</sourcefields>
			</ps_buttongroup_rating_title_red>

			<label_crewheader name="heat_header">
				<static textres="ps_title_heat" />
				<anchored to="rightanchor">
					<right relation="relative" offset="-5" />
					<top offset="5" />
				</anchored>
			</label_crewheader>

			<label_crewframetop_textonly name="header">
				<anchored height="30">
					<top offset="12" />
					<left parent="leftanchor" relation="relative" offset="10" />
					<right parent="rightanchor" relation="relative" offset="-10" />
				</anchored>
				<font>crewheader</font>
			</label_crewframetop_textonly>

			<spacer_content_top />

			<sub_content_top name="content">
				<class>ps_system_content</class>
			</sub_content_top>
		</sheetdata>
	</windowclass>

	<windowclass name="ps_system_content">
		<margins control="10,5,5,0" />
		<sheetdata>
			<anchor_content_top />
			<anchor_content_bottom />

			<stringc_content_noframe_noscroll_static_top name="description" />
		</sheetdata>
	</windowclass>
</root>