<root>
	<windowclass name="clock" copy="record_window">
		<sizelimits>
			<minimum height="500" />
		</sizelimits>
	</windowclass>
	<windowclass name="clock_header" copy="record_header_id" />
	
	<windowclass name="clock_main">
		<script file="campaign/scripts/clock_main.lua" />
		<sheetdata>
			<anchor_content_top />
			<anchor_content_bottom />

			<hn name="size" />

			<label_content_column name="size_label">
				<static textres="clock_label_size" />
			</label_content_column>
			<comboboxc_content_column_sizeselector name="size_selector">
				<control>size</control>
			</comboboxc_content_column_sizeselector>

			<label_content_column name="progress_label">
				<static textres="clock_label_progress" />
			</label_content_column>
			<number_content_column_clockprogress name="progress">
				<maxsource>size</maxsource>
			</number_content_column_clockprogress>

			<button_content_top_clock_center name="clock">
				<sourcefields>
					<size>size</size>
					<progress>progress</progress>
				</sourcefields>
			</button_content_top_clock_center>
			
			<ft_content name="notes">
				<anchored>
					<top offset="20" />
				</anchored>
				<nodrag />
			</ft_content>
		</sheetdata>
	</windowclass>

	<!-- COMMON CLOCKS TAB -->
	<windowclass name="tab_clocks">
		<margins control="0,0,0,2" />
		<script>
			function onInit()
				self.update();
			end
			function update()
				local bReadOnly = WindowManager.getReadOnlyState(getDatabaseNode());
				local tFields = { "clocks", "clocks_iadd" };
				WindowManager.callSafeControlsUpdate(self, tFields, bReadOnly);
			end
		</script>
		<sheetdata>
			<anchor_content_top />

			<header_content_framed_headersimple name="header_clocks">
				<static textres="clock_header_clocks" />
			</header_content_framed_headersimple>

			<button_iadd name="clocks_iadd">
				<script>
					function update(bReadOnly)
						setVisible(not bReadOnly)
					end
				</script>
				<anchored to="header_clocks" position="insidetopright" offset="2,0" />
				<target>clocks</target>
				<gmvisibleonly />
			</button_iadd>

			<list_content_noscroll_top name="clocks">
				<script>
					function update(bReadOnly)
						for _, w in ipairs(getWindows()) do
							w.update(bReadOnly);
						end
					end
					function onFilter(w)
						if Session.IsHost then
							return true;
						end
						
						return w.visible.getValue() == 1;
					end
				</script>
				<datasource>.clocks</datasource>
				<class>clock_listitem</class>
				<allowdelete />
			</list_content_noscroll_top>
		</sheetdata>
	</windowclass>

	<windowclass name="clock_listitem">
		<margins control="0,0,0,20" />
		<script>
			function update(bReadOnly)
				local tFields = { "name", "notes", "clock", "sizeselector", "visible" };
				WindowManager.callSafeControlsUpdate(self, tFields, bReadOnly);
			end
		</script>
		<sheetdata>
			<anchor_content_top />
			<anchor_content_bottom />
			<hn name="size">
				<default>4</default>
			</hn>
			<hn name="progress">
				<default>0</default>
			</hn>

			<anchor_listitem_right />

			<linkcontrol_record name="shortcut">
				<anchored to="rightanchor" height="20" width="20">
					<top />
					<right relation="relative" offset="-2" postoffset="-2" />
				</anchored>
				<class>clock</class>
			</linkcontrol_record>

			<button_visibility_listitem_right name="visible" />
			
			<comboboxc_content_top_sizeselector name="sizeselector">
				<anchored width="100">
					<left offset="10" />
				</anchored>
				<control>size</control>
			</comboboxc_content_top_sizeselector>

			<string_labeled name="name">
				<anchored to="sizeselector" height="20">
					<top />
					<left anchor="right" offset="20" />
					<right parent="rightanchor" relation="relative" offset="-5" />
				</anchored>
				<labelres>clock_label_name</labelres>
			</string_labeled>

			<button_content_top_clock name="clock">
				<sourcefields>
					<size>size</size>
					<progress>progress</progress>
				</sourcefields>
				<anchored width="120" height="120">
					<top offset="-5" />
					<left />
				</anchored>
			</button_content_top_clock>

			<simpleft name="notes">
				<anchored to="clock">
					<top parent="name" anchor="bottom" offset="15" />
					<bottom />
					<left anchor="right" offset="20" />
					<right parent="" offset="-20" />
				</anchored>
				<frame mergerule="replace" name="fielddark" offset="10,5,20,5" hidereadonly="true" />
				<stateframe>
					<keyedit name="fieldfocus" offset="10,5,20,5" />
					<hover name="fieldfocus" offset="10,5,20,5" hidereadonly="true" />
					<drophilight name="fieldfocus" offset="10,5,20,5" hidereadonly="true" />
				</stateframe>
				<empty textres="ft_empty" hidereadonly="true" />
			</simpleft>
		</sheetdata>
	</windowclass>
</root>
