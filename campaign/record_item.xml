<root>
	<windowclass name="item_main">
		<margins control="0,0,0,2" />
		<script file="campaign/scripts/item_main.lua" />
		<sheetdata>
			<anchor_content_top />

			<sub_record_nonid_notes name="sub_nonid" />
			
			<label_content_column name="load_label">
				<static textres="item_label_load" />
			</label_content_column>
			<number_content_column name="load">
				<min>0</min>
				<default>1</default>
			</number_content_column>

			<button_stringcycler name="load_type">
				<anchored height="20">
					<top parent="load" anchor="top" />
					<left parent="load" anchor="right" offset="10" />
					<right parent="" anchor="right" offset="-10" />
				</anchored>
				<tooltip textres="tooltip_item_load_amount" />
				<parameters>
					<labelsres>item_load_multiple</labelsres>
					<values>multi</values>
					<defaultlabelres>item_load_single</defaultlabelres>
				</parameters>
			</button_stringcycler>

			<label_content_column name="quality_label">
				<static textres="item_label_quality" />
			</label_content_column>
			<button_checkbox_content_column name="quality" />

			<line_content_top name="divider" />
			
			<ft_content_columnh_full name="notes" />
		</sheetdata>
	</windowclass>
</root>